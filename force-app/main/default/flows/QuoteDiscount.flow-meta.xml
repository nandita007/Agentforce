    <assignments>
        <name>Add_Discount</name>
        <label>Add Discount</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>loop_over_line_items.SBQQ__Discount__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>DiscountNBR</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>assign_the_items</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>assign_the_items</name>
        <label>assign the items</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>totalrows</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>row</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>totalpriceall</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>pricevalue</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>loop_over_line_items</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Output</name>
        <label>Output</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>OutputMessage</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Email sent successfully</stringValue>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Update_Discount</name>
        <label>Update Discount</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>GETQUOTE.SBQQ__CustomerDiscount__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>DiscountNBR</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_quote</targetReference>
        </connector>
    </assignments>
    <environments>Default</environments>
    <formulas>
        <name>calprice</name>
        <dataType>Number</dataType>
        <expression>{!netpriceval}*{!loop_over_line_items.SBQQ__Quantity__c}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>pricetotal</name>
        <dataType>Number</dataType>
        <expression>{!loop_over_line_items.SBQQ__Quantity__c}*{!loop_over_line_items.SBQQ__ListPrice__c}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>pricevalue</name>
        <dataType>Number</dataType>
        <expression>{!loop_over_line_items.SBQQ__ListPrice__c}*{!loop_over_line_items.SBQQ__Quantity__c}*(1-({!DiscountNBR}/100))</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>QuoteDiscount {!$Flow.CurrentDateTime}</interviewLabel>
    <label>QuoteDiscount</label>
    <loops>
        <name>loop_over_line_items</name>
        <label>loop over line items</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_quote_line</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Add_Discount</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Send_quote_details</targetReference>
        </noMoreValuesConnector>
    </loops>
